---
import siteConfig from "../config/site.json";
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <a href="#top" class="footer-logo font-display">
        STACK'D <span class="gold">FRIES</span>
      </a>
    </div>
    <div class="footer-right">
      <a
        href={siteConfig.social.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="footer-social font-label"
        data-track="social_click_instagram"
      >Instagram</a>
      <a
        href={siteConfig.social.tiktok}
        target="_blank"
        rel="noopener noreferrer"
        class="footer-social font-label"
        data-track="social_click_tiktok"
      >TikTok</a>
      <a
        href={siteConfig.social.facebook}
        target="_blank"
        rel="noopener noreferrer"
        class="footer-social font-label"
        data-track="social_click_facebook"
      >Facebook</a>
    </div>
  </div>
  <div class="container footer-bottom">
    <p class="footer-copy">&copy; 2026 Stack'd Fries, LLC. Norman, OK.</p>
  </div>
</footer>

<style>
  .footer {
    padding: 40px 0 24px;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .footer-logo {
    font-size: 20px;
    color: var(--text-primary);
    letter-spacing: 1px;
  }

  .gold {
    color: var(--brand-gold);
  }

  .footer-right {
    display: flex;
    gap: 16px;
  }

  .footer-social {
    font-size: 12px;
    color: var(--text-secondary);
    padding: 6px 16px;
    border: 1px solid var(--border-subtle);
    border-radius: 50px;
    transition: all var(--transition-fast);
  }

  .footer-social:hover {
    border-color: var(--brand-gold);
    color: var(--brand-gold);
  }

  .footer-bottom {
    text-align: center;
  }

  .footer-copy {
    font-size: 12px;
    color: var(--text-muted);
  }

  @media (max-width: 767px) {
    .footer-inner {
      flex-direction: column;
      gap: 20px;
    }

    .footer-right {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
