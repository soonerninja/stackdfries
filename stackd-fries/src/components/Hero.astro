---
import siteConfig from "../config/site.json";
import { getStatusText } from "../utils/hours";

const status = getStatusText();
---

<section class="hero" id="top">
  <div class="hero-glow"></div>
  <div class="hero-content container">
    <p class="hero-logo font-display hero-anim" style="--delay: 0ms">
      STACK'D <span class="gold">FRIES</span>
    </p>
    <h1 class="hero-tagline font-display hero-anim" style="--delay: 200ms">
      LOADED.<br /><span class="gold">ALWAYS.</span>
    </h1>
    <p class="hero-subtitle font-label hero-anim" style="--delay: 400ms">
      {siteConfig.subtitle}
    </p>
    <div class="hero-ctas hero-anim" style="--delay: 600ms">
      <a
        href={siteConfig.orderUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary"
        data-track="order_click_hero"
      >Order Now</a>
      <a href="#menu" class="btn btn-outline" data-track="menu_scroll">See the Menu</a>
    </div>
  </div>

  <div class="hero-status" id="hours-status">
    <span class={`status-dot ${status.isOpen ? "open" : "closed"}`}></span>
    <span class="status-text font-label">{status.text}</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 50% 40%,
      rgba(212, 168, 67, 0.08) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-logo {
    font-size: 22px;
    letter-spacing: 2px;
    margin-bottom: 16px;
    color: var(--text-primary);
  }

  .gold {
    color: var(--brand-gold);
  }

  .hero-tagline {
    font-size: 64px;
    line-height: 1.05;
    margin-bottom: 16px;
  }

  .hero-subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: 32px;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Staggered fade-in */
  .hero-anim {
    opacity: 0;
    transform: translateY(16px);
    animation: heroFadeUp 600ms ease forwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes heroFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hours badge */
  .hero-status {
    position: absolute;
    bottom: 32px;
    right: 32px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--brand-dark-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    z-index: 1;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .status-dot.open {
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.5);
  }

  .status-dot.closed {
    background: var(--brand-red);
  }

  .status-text {
    font-size: 12px;
    color: var(--text-secondary);
  }

  @media (max-width: 767px) {
    .hero-tagline {
      font-size: clamp(36px, 10vw, 52px);
    }

    .hero-subtitle {
      font-size: 13px;
    }

    .hero-status {
      bottom: 80px; /* above mobile CTA */
      right: 16px;
    }

    .hero-ctas .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
